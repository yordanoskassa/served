{
  "schema_version": "1.0.0",
  "verified_on": "2026-07-16",
  "scope": {
    "release": "hackathon-prototype-v1",
    "description": "Intentionally limited July demo court-routing seed. Read this boundary before extending.",
    "included_federal_courts": 5,
    "included_state_court_stubs": 1,
    "included_fixture_only_fictitious_authorities": 1,
    "july_demo_scope": {
      "federal": [
        "The four United States District Courts in California",
        "United States Court of Appeals for the Ninth Circuit"
      ],
      "fake_authority_fixture": "D3's fictional Federal Legal Processing Bureau"
    },
    "not_in_directory_behavior": {
      "result": "UNKNOWN_AUTHORITY",
      "action": "Route to human review.",
      "scam_threshold_contribution": 0,
      "rule": "A real out-of-state or other federal court may simply be outside this seed. Absence is not evidence of fraud, exactly as a RECAP docket miss is not evidence of fraud. Directory-only authority findings remain annotation-only.",
      "only_positive_fraud_matches_count": true
    },
    "out_of_scope": [
      "Federal districts outside California",
      "State courts beyond the optional Los Angeles Superior Court stub",
      "Tribal courts",
      "Administrative bodies",
      "Fuzzy matching that automatically declares a court official",
      "Automated state-court docket verification",
      "Using a directory miss as a scam signal"
    ],
    "planned_extension_window": "August"
  },
  "normalization": {
    "steps": [
      "Apply Unicode NFKC normalization",
      "Convert to lowercase",
      "Replace ampersands with the word and",
      "Remove punctuation except hyphens inside case numbers",
      "Collapse repeated whitespace",
      "Trim leading and trailing whitespace"
    ],
    "automatic_match_policy": "Only normalized exact matches against canonical_name or aliases may return OFFICIAL_COURT.",
    "fuzzy_match_policy": "A similar-looking name may return NAME_MISMATCH for review, but must never return OFFICIAL_COURT automatically."
  },
  "match_outcomes": {
    "OFFICIAL_COURT": {
      "meaning": "The normalized name exactly matches a seeded official court name or alias.",
      "scam_threshold_contribution": 0
    },
    "NAME_MISMATCH": {
      "meaning": "The name resembles a known court but is not an exact seeded name or alias.",
      "action": "Request human review or ask the user to verify the court on its official website.",
      "scam_threshold_contribution": 0
    },
    "UNKNOWN_AUTHORITY": {
      "meaning": "No exact official-court match was found in this limited seed.",
      "action": "Treat as annotation-only and route to human verification.",
      "scam_threshold_contribution": 0
    }
  },
  "global_guardrails": [
    "A court-directory miss is annotation-only and never counts toward the two-signal scam threshold.",
    "A case-number format mismatch is annotation-only until two teammates independently spot-check the rule.",
    "A CourtListener or RECAP miss yields CANNOT_CONFIRM, not SCAM.",
    "The directory contract designates CourtListener or RECAP for federal routes; runtime directory enforcement remains a release gate.",
    "The state-court stub has no dedicated automated public-docket integration in the current prototype and therefore cannot independently establish VERIFIED.",
    "No court name, domain, or case-number pattern alone decides the final verdict."
  ],

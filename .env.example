# EasyPanel: add these as backend service environment variables.
# Reuse values from Lumper where indicated; never commit the real values.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
COURTLISTENER_API_TOKEN=

# Reuse Lumper Mongo deployment, but keep Served data in its own database.
MONGODB_URI=
SERVED_MONGODB_DB=served

# Reuse Lumper Google OAuth credentials. Add the Served EasyPanel domain
# to Authorized JavaScript origins in Google Cloud before enabling login.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional document storage; reuse Lumper's AWS account with a separate bucket/prefix.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-2
S3_BUCKET=

SERVED_CORS_ORIGINS=["http://localhost:5173"]

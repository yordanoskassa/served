# EasyPanel: add these as backend service environment variables.
# Reuse values from Lumper where indicated; never commit the real values.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
COURTLISTENER_API_TOKEN=

# Resend transactional email. Verify the sender domain in Resend first.
# Keep the API key in EasyPanel's secret environment settings only.
SERVED_RESEND_API_KEY=
SERVED_RESEND_FROM_EMAIL="Served <handoff@your-domain.example>"
SERVED_RESEND_REPLY_TO=

# Reuse Lumper Mongo deployment, but keep Served data in its own database.
MONGODB_URI=
SERVED_MONGODB_DB=served

# Reuse Lumper Google OAuth credentials. Add the Served EasyPanel domain
# to Authorized JavaScript origins in Google Cloud before enabling login.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Plaid (Cook agent — bank auth + real transactions). Same client ID for all envs;
# set PLAID_ENVIRONMENT=production and use PLAID_PRODUCTION_SECRET in EasyPanel prod.
# D4 sample connect always calls sandbox.plaid.com — keep PLAID_SANDBOX_SECRET set even when
# PLAID_ENVIRONMENT=development (Link uses development; seeded Mendoza account uses sandbox).
PLAID_CLIENT_ID=
PLAID_SANDBOX_SECRET=
PLAID_PRODUCTION_SECRET=
PLAID_ENVIRONMENT=sandbox
# Optional override; otherwise sandbox/production secret is chosen from PLAID_ENVIRONMENT.
PLAID_SECRET=
# OAuth institutions (Chase, Wells Fargo, Platypus OAuth Bank, etc.): add the same URL in Plaid Dashboard → Allowed redirect URIs.
# Production / Netlify example (no query string, no hash):
PLAID_REDIRECT_URI=https://servedai.netlify.app/

# Optional document storage; reuse Lumper's AWS account with a separate bucket/prefix.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-2
S3_BUCKET=

SERVED_CORS_ORIGINS=["http://localhost:5173","https://servedai.netlify.app"]
